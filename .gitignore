# ─── Large / sensitive data files ────────────────────────────
# Raw Excel files are tracked; exclude any CSVs exported from
# private or sensitive sources that should not be in version control.
# data/private/
# *.csv          <-- NOT ignored; processed CSVs are part of the repo

# Exclude large binary model artefacts
*.pkl
*.joblib
*.h5
*.onnx

# ─── OS artefacts ────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

